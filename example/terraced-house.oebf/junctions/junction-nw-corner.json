{
  "$schema": "oebf://schema/0.1/junction",
  "id": "junction-nw-corner",
  "type": "Junction",
  "description": "NW corner: north wall butts into west wall (west wall runs through)",
  "elements": ["element-wall-north-gf", "element-wall-west-gf"],
  "rule": "butt",
  "priority": ["element-wall-west-gf"],
  "trim_planes": [{
    "element_id": "element-wall-north-gf",
    "at_end": "start",
    "plane_normal": { "x": 1, "y": 0, "z": 0 },
    "plane_origin": { "x": 0.0, "y": 8.5, "z": 0.0 }
  }]
}
