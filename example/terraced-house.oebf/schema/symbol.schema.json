{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "oebf://schema/0.1/symbol",
  "title": "OEBF Symbol (Type Definition)",
  "type": "object",
  "required": ["id", "type", "ifc_type", "parameters"],
  "additionalProperties": false,
  "properties": {
    "$schema":              { "type": "string" },
    "id":                   { "type": "string" },
    "type":                 { "type": "string", "const": "Symbol" },
    "description":          { "type": "string" },
    "ifc_type":             { "type": "string" },
    "parameters":           { "type": "object" },
    "geometry_definition":  { "type": "string" },
    "ifc_predefined_type":  { "type": "string" }
  }
}
