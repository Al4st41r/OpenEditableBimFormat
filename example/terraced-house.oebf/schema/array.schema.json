{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "oebf://schema/0.1/array",
  "title": "OEBF Array",
  "$comment": "v0.1: Always parametric. Instance positions are computed at load time from path geometry and spacing parameters. No 'instances' array is ever stored in this file.",
  "type": "object",
  "required": ["$schema", "id", "type", "source_id", "path_id", "mode", "alignment", "axes"],
  "additionalProperties": false,
  "properties": {
    "$schema":           { "type": "string" },
    "id":                { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "type":              { "type": "string", "const": "Array" },
    "description":       { "type": "string" },
    "source_id":         { "type": "string" },
    "path_id":           { "type": "string" },
    "mode":              { "type": "string", "enum": ["spacing", "count", "fill"] },
    "spacing":           { "type": ["number", "null"] },
    "count":             { "type": ["integer", "null"] },
    "start_offset":      { "type": "number", "default": 0 },
    "end_offset":        { "type": "number", "default": 0 },
    "alignment":         { "type": "string", "enum": ["tangent", "perpendicular", "fixed"] },
    "axes":              { "type": "array", "items": { "type": "string", "enum": ["x","y","z"] } },
    "offset_local":      {
      "type": "object",
      "required": ["x","y","z"],
      "properties": { "x": {"type":"number"}, "y": {"type":"number"}, "z": {"type":"number"} }
    },
    "rotation_local_deg": { "type": "number", "default": 0 }
  }
}
