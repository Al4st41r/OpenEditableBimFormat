{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "oebf://schema/0.1/grid",
  "title": "OEBF Grid",
  "type": "object",
  "required": ["$schema", "id", "type", "description", "axes", "ifc_type"],
  "additionalProperties": false,
  "properties": {
    "$schema":     { "type": "string" },
    "id":          { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "type":        { "type": "string", "const": "Grid" },
    "description": { "type": "string" },
    "ifc_type":    { "type": "string" },
    "axes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": ["id", "direction", "offset_m"],
            "properties": {
              "id":        { "type": "string" },
              "direction": { "type": "string", "enum": ["x", "y"] },
              "offset_m":  { "type": "number" }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": ["id", "direction", "angle_deg"],
            "properties": {
              "id":        { "type": "string" },
              "direction": { "type": "string", "const": "radial" },
              "angle_deg": { "type": "number" },
              "origin":    { "$ref": "#/definitions/point2" }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": ["id", "direction", "radius_m"],
            "properties": {
              "id":        { "type": "string" },
              "direction": { "type": "string", "const": "arc" },
              "radius_m":  { "type": "number", "exclusiveMinimum": 0 },
              "origin":    { "$ref": "#/definitions/point2" }
            },
            "additionalProperties": false
          }
        ]
      }
    },
    "elevations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "z_m"],
        "additionalProperties": false,
        "properties": {
          "id":          { "type": "string" },
          "z_m":         { "type": "number" },
          "description": { "type": "string" }
        }
      }
    }
  },
  "definitions": {
    "point2": {
      "type": "object",
      "required": ["x", "y"],
      "additionalProperties": false,
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    }
  }
}
